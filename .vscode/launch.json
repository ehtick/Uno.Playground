{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Uno Playground WebAssembly Debug (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:51258",
      "webRoot": "${workspaceFolder}/src/Uno.Playground",
      "inspectUri": "{wsProtocol}://{url.hostname}:{url.port}/_framework/debug/ws-proxy?browser={browserInspectUri}",
      "timeout": 30000,
      "preLaunchTask": "build-wasm",
      "server": {
        "runtimeExecutable": "dotnet",
        "program": "run",
        "args": ["--no-build", "-f", "net10.0-browserwasm", "--launch-profile", "Uno.Playground"],
        "outputCapture": "std",
        "timeout": 30000,
        "cwd": "${workspaceFolder}/src/Uno.Playground"
      }
    },
    {
      "name": "Uno Playground WebAssembly Debug (Edge)",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:51258",
      "webRoot": "${workspaceFolder}/src/Uno.Playground",
      "inspectUri": "{wsProtocol}://{url.hostname}:{url.port}/_framework/debug/ws-proxy?browser={browserInspectUri}",
      "timeout": 30000,
      "preLaunchTask": "build-wasm",
      "server": {
        "runtimeExecutable": "dotnet",
        "program": "run",
        "args": ["--no-build", "-f", "net10.0-browserwasm", "--launch-profile", "Uno.Playground"],
        "outputCapture": "std",
        "timeout": 30000,
        "cwd": "${workspaceFolder}/src/Uno.Playground"
      }
    }
  ]
}
